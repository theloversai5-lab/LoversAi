# Example production environment variables for deployment
PORT=5000
NODE_ENV=production

# MongoDB (placeholder)
MONGO_URI=your_mongo_connection_string_here

# Cloudinary placeholders - set real values in your secrets manager or CI
CLOUDINARY_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
